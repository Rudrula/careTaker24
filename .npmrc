# React 19 is new enough that a lot of third-party React Native packages
# haven't updated their peerDependencies ranges yet, even when the package
# itself works fine with it. Without this, npm treats every one of those
# stale ranges as a hard error (ERESOLVE) instead of a warning — this is
# the standard, widely-used fix for that entire class of problem across
# the current React Native/Expo SDK 54 ecosystem, not a one-off patch for
# a single package.
legacy-peer-deps=true
