{
  "expo": {
    "name": "Caretaker24",
    "slug": "caretaker24",
    "version": "1.0.0",
    "scheme": "caretaker24",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A2856"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      "expo-dev-client",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1A2856",
          "sounds": ["./assets/sounds/alarm.wav"]
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.caretaker24.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan prescription photos and bill photos.",
        "NSPhotoLibraryUsageDescription": "Used to select prescription or bill photos.",
        "NSMotionUsageDescription": "Used to count your daily steps for the walking tracker.",
        "NSFaceIDUsageDescription": "Used to keep Caretaker24 locked with Face ID when you're not actively using it.",
        "NSLocationWhenInUseUsageDescription": "Used to include your location in an SOS emergency alert so family can find you."
      }
    },
    "android": {
      "package": "com.caretaker24.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A2856"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACTIVITY_RECOGNITION",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "VIBRATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
